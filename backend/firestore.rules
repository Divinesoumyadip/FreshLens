rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read/write own doc only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reports: authenticated users can read verified; only owner can write
    match /fraud_reports/{reportId} {
      allow read: if request.auth != null && resource.data.status == 'verified';
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Heatmap: read-only for all authenticated users
    match /heatmap_points/{pointId} {
      allow read: if request.auth != null;
      allow write: if false; // only backend writes via Admin SDK
    }

    // Restaurants: read only
    match /restaurants/{restaurantId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
